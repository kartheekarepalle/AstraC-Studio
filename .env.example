# Example environment variables for backend
# Path to a host tinyc binary (optional)
TINYC_PATH=

# Optional: Docker image tag that contains a tinyc executable.
# If set, the backend will try to run tinyc inside the container
# using this image. Example:
# TINYC_DOCKER_IMAGE=mini-compiler-tinyc:local
TINYC_DOCKER_IMAGE=

# If your tinyc executable in the image is named differently, set this
# TINYC_DOCKER_CMD=tinyc
