{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "installCommand": "npm install",
        "buildCommand": "npm run vercel-build"
      }
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/compile-run", "dest": "/api/compile_run.py" },
    { "src": "/api/health",      "dest": "/api/health.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)",           "dest": "/frontend/$1" }
  ]
}
